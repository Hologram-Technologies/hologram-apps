  "a12:torus": {
    "@type": [
      "owl:Class",
      "schema:StructuredValue"
    ],
    "rdfs:label": "Discrete torus T² = ℤ₄₈ × ℤ₂₅₆",
    "rdfs:comment": "The boundary's periodic (cyclic) page and byte axes (mathematics.md §Topology) make it a discrete 2-torus with 12,288 lattice points; R96 quotients the byte fiber into 96 classes."
  },
  "hosc:hypothesis": {
    "@type": "prov:Entity",
    "schema:name": "96-vertex / 12,288 torus as LLM latent topology",
    "schema:disambiguatingDescription": "WORKING HYPOTHESIS, not a proven property of atlas-12288: that this torus is a coordinate system for the topological space every LLM maps into. Recorded as a claim to be tested; it asserts nothing about the verified upstream mathematics.",
