{
  "manifest_version": 3,
  "name": "Holo Popup Test",
  "version": "1.0",
  "key": "",
  "description": "Proves the κ-rail extension proxy opens a real extension popup.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Holo Popup"
  },
  "content_scripts": [
    {
      "matches": [
        "https://example.com/*"
      ],
      "js": [
        "cs.js"
      ],
      "run_at": "document_end"
    }
  ]
}