#!/bin/bash
# tamper — integrity by construction: change ONE byte and the content address changes utterly.
# That is exactly why the κ-gate refuses a corrupted kernel or rootfs. Shown live with two
# tiny files that differ by a single byte — not asserted, demonstrated.

A=$'\033[1;38;5;51m'; D=$'\033[38;5;244m'; B=$'\033[38;5;39m'; Y=$'\033[38;5;220m'; R=$'\033[0m'

printf '\n%sHolo Linux is tamper-evident%s\n\n' "$A" "$R"

printf 'HOLO-LINUX' > /tmp/orig.bin
printf 'XOLO-LINUX' > /tmp/bent.bin     # byte-for-byte identical but for the very first character
o=$(sha256sum /tmp/orig.bin | awk '{print $1}')
b=$(sha256sum /tmp/bent.bin | awk '{print $1}')

printf '  %sHOLO-LINUX%s  →  %s\n' "$B" "$R" "$o"
printf '  %sXOLO-LINUX%s  →  %s\n' "$B" "$R" "$b"

printf '\n%sOne byte changed; the entire κ changed.%s\n' "$Y" "$R"
printf '%sThe boot re-derives the kernel + rootfs κ and refuses any mismatch. Press the\n' "$D"
printf '⚠ tamper test in the toolbar to watch a single flipped rootfs byte stop the\n'
printf 'machine cold — a corrupted download simply cannot run here.%s\n\n' "$R"
