#!/bin/bash
# fingerprint — every byte is admitted by its content address (κ), not by trust (Law L5).
# The host re-derives the SHA-256 of the kernel + rootfs and refuses to boot on any mismatch;
# here we compute the same kind of content addresses LIVE, from inside the κ-verified guest.

A=$'\033[1;38;5;51m'; D=$'\033[38;5;244m'; B=$'\033[38;5;39m'; R=$'\033[0m'

printf '\n%sHolo Linux is κ-addressable%s\n\n' "$A" "$R"

printf '%sThe kernel and rootfs booted only because their SHA-256 matched the content\n' "$D"
printf 'address pinned in kappa.json — re-derived before the first instruction ran.%s\n\n' "$R"

printf '%scontent address (sha256) of files in this κ-verified rootfs:%s\n' "$B" "$R"
sha256sum /etc/os-release /etc/profile.d/00-holo-linux.sh /usr/local/bin/verify 2>/dev/null | sed 's/^/  /'

printf '\n%sIdentity by content, not by hostname, server, or trust. See the  ✓ κ-anchored\n' "$D"
printf 'rail above the terminal for the kernel + rootfs κ, re-derived on THIS boot.%s\n\n' "$R"
