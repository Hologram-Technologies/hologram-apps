#!/bin/bash
# verify — prove this is a real Linux kernel, not a scripted shell. Every check below reads
# state the kernel SYNTHESISES at runtime (/proc, the ring buffer, the CSPRNG, the VFS).
# A command->string mock cannot reproduce any of it. Run it, read the "why", check it yourself.

A=$'\033[1;38;5;51m'; D=$'\033[38;5;244m'; Y=$'\033[38;5;220m'; R=$'\033[0m'
step() { printf '\n%s== %s%s\n%s# %s%s\n' "$A" "$1" "$R" "$Y" "$2" "$R"; eval "$2"; }
why()  { printf '%s   why: %s%s\n' "$D" "$1" "$R"; }

printf '\n%sHolo Linux self-verification%s\n' "$A" "$R"

why "release, arch and SMP build string come straight from the running kernel"
step "kernel identity" "uname -a"

why "/proc/cpuinfo is generated by the kernel — real RISC-V harts, ISA extensions, MMU mode"
step "the CPU" "grep -E 'processor|isa|mmu|hart' /proc/cpuinfo"

why "real PIDs in a real process table; PID 1 is init — no /proc fakery possible"
step "process table (from /proc, no ps needed)" "ls -d /proc/[0-9]* | sed 's#/proc/##' | tr '\n' ' '; echo; echo -n 'PID1 = '; cat /proc/1/comm"

why "the kernel's own boot ring buffer — a script has no dmesg to show"
step "kernel ring buffer" "dmesg | tail -6"

why "real VFS: an ext4 root on the virtio block device, plus proc/sysfs/devtmpfs"
step "mounted filesystems" "mount | grep -E 'ext4|proc|sysfs|devtmpfs'"

why "two reads of the kernel CSPRNG give two different UUIDs — not a constant"
step "kernel entropy" "cat /proc/sys/kernel/random/uuid; cat /proc/sys/kernel/random/uuid"

why "write to the real ext4, sync, hash it back — bytes round-trip through a real fs"
step "filesystem round-trip" "head -c 4096 /dev/urandom > /tmp/holo.bin && sync && sha256sum /tmp/holo.bin && ls -l /tmp/holo.bin"

printf '\n%sAll output above was produced by the kernel/userland in this tab. Nothing was scripted.%s\n\n' "$A" "$R"
