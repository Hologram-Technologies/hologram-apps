#!/bin/bash
# reproduce — this machine is defined by content, not by a server. Every file in the rootfs is
# content-addressed: the same bytes give the same κ on every boot, on any device. The whole
# kernel + rootfs are pinned by κ in kappa.json and re-derived at boot (the ✓ κ-anchored rail
# above) — so a few hex characters reproduce the identical OS, byte-for-byte, anywhere, forever.

A=$'\033[1;38;5;51m'; D=$'\033[38;5;244m'; B=$'\033[38;5;39m'; R=$'\033[0m'

printf '\n%sHolo Linux is reproducible%s\n\n' "$A" "$R"

printf '%sSame bytes → the same κ, on every boot and on any machine. A few derived live now:%s\n\n' "$D" "$R"
sha256sum /etc/os-release /etc/profile.d/00-holo-linux.sh /usr/local/bin/verify 2>/dev/null | sed 's/^/  /'

printf '\n%sThe whole machine — this exact kernel + rootfs — is pinned by κ in kappa.json and\n' "$D"
printf 're-derived at boot (see the  ✓ κ-anchored  rail above the terminal). Hand someone\n'
printf 'that κ and they rebuild this OS byte-for-byte — no server, no trust, no drift.%s\n\n' "$R"
