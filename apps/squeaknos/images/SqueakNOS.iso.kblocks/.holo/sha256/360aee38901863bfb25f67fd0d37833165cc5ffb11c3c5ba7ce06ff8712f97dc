ce	"Initialize the receiver to be associated with the player and category specified"	super initializeFor: aPlayer categoryChoice: #search.	(namePane findA: PluggableTextMorph) setText: aChoice second asText.	self setCategorySymbolFrom: aChoice! !!SearchingViewer methodsFor: 'initialization' stamp: 'sw 8/22/2002 23:09'!setCategorySymbolFrom: aChoice	"Set my category symbol"	self chosenCategorySymbol: #search.	self rawSearchString: aChoice second! !!SearchingViewer methodsFor: 'search' stamp: 'sw 4/10/2003 21:36'!doSearchFrom:  aSource
