ePaneFiltered: #initialDirectoryList! !!FileList2 methodsFor: 'user interface' stamp: 'rww 12/13/2003 13:07'!morphicDirectoryTreePaneFiltered: aSymbol	^(SimpleHierarchicalListMorph 		on: self		list: aSymbol		selected: #currentDirectorySelected		changeSelected: #setSelectedDire