il: 			[(aScriptableObject isPlayerLike) ifTrue: [^Vocabulary eToyVocabulary].			(aScriptableObject isNumber) 				ifTrue: [^Vocabulary numberVocabulary].			(aScriptableObject isKindOf: Time) 				ifTrue: [^Vocabulary vocabularyForClass: Time].			(aScriptableObject isString) 				ifTrue: [^Vocabulary vocabularyForClass: String].			(aScriptableObject isPoint) 				ifTrue: 					[(aPointVocab := Vocabulary vocabularyForClass: Point) 						ifNotNil: [^aPointVocab]].			(aScriptableObject isKindOf: Date) 				ifTrue: [^Vocabulary vocabularyForClass: Date].			"OrderedCollection and Holder??"			^Vocabulary fullVocabulary]! !!PasteUpMorph methodsFor: 'scripting' stamp: 'sw 2/18/2003 02:56'!elementCount
