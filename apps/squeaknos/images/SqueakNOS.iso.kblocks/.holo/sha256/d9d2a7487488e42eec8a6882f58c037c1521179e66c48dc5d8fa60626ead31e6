int main(int argc, char **argv) {
	FILE *imageFile;
	char *image,*p;
	unsigned int size,r;

	if (!(imageFile = fopen(argv[1], "rb"))) {
		perror("opening image file");
		return 1;
	}

	fseek(imageFile, 0, SEEK_END);
	size = ftell(imageFile);
	fseek(imageFile, 0, SEEK_SET);

	p = image = malloc(initialHeapSize);

	do {
		r = fread(p, 1, size, imageFile);
		if (r < 0) {
			perror("reading image file");
			break;
		} else {
			p += r;
			size -= r;
		}
	} while (size);

