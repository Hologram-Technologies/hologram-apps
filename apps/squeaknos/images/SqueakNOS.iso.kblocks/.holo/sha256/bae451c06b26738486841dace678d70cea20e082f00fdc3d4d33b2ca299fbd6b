		/* begin byteSwapByteObjects */
		byteSwapByteObjectsFromto(memory + (headerTypeBytes[(longAt(memory)) & TypeMask]), endOfMemory);
	}
	bytesToShift = memStart - oldBaseAddr;
	initializeInterpreter(bytesToShift);
	isBigEnder();
	return dataSize;
}


