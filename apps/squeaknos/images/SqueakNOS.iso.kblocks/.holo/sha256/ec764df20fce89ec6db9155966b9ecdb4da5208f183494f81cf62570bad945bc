					case MPEG3_601_RGBA8888:
					case MPEG3_601_ARGB8888:
					case MPEG3_601_RGB888:
						DITHER_MMX_SCALE_HEAD
							mpeg3_601_rgba32_mmx(y_in[video->x_table[w]], 
