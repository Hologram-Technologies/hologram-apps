%rep 8
  movq       mm0, [edi]		; get dest
  movq	     mm1,mm0		
  punpcklbw  mm0,mm2
  punpckhbw  mm1,mm2
  paddsw     mm0, [esi]
  paddsw     mm1, [esi+8]
;  paddsw     mm0, mm7
;  paddsw     mm1, mm7
  packuswb   mm0,mm1	     
  movq	     [edi], mm0
  add        edi,ebx
  add	     esi,16
%endrep
  emms
  pop        edx
  pop	     ebx
  pop        ecx
  pop        edi
  pop        esi
  ret

  align 16
set_block_mmx:
  push       esi
  push       edi
  push       ecx
  push       ebx
  push       edx
  mov        esi, [esp+bp]
  mov        edi, [esp+rfp]
  mov        ebx, [esp+iincr]
  movq       mm7, [PLUS_128]
%rep 4
  movq       mm0, [esi]
  movq       mm1, [esi+8]
  paddsw     mm0, mm7
  movq       mm2, [esi+16]
  paddsw     mm1, mm7
  movq       mm3, [esi+24]
  paddsw     mm2, mm7
  packuswb   mm0, mm1
  paddsw     mm3, mm7
  movq       [edi], mm0
  packuswb   mm2, mm3
  add        edi, ebx
  add        esi, 32
  movq       [edi], mm2
  add        edi, ebx
%endrep
  emms
  pop        edx
  pop        ebx
  pop        ecx
  pop        edi
  pop        esi
  ret


