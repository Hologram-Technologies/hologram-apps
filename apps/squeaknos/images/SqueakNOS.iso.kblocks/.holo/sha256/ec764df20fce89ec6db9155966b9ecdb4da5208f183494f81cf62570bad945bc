						DITHER_TAIL
						break;
					case MPEG3_RGBI555:
						DITHER_HEAD
						STORE_PIXEL_RGBI555
						DITHER_TAIL
						break;
					case MPEG3_RGB888:
						DITHER_HEAD
						STORE_PIXEL_RGB888
						DITHER_TAIL
						break;
					case MPEG3_RGBA8888:
						DITHER_HEAD
						STORE_PIXEL_RGBA8888
