nitialBeta].	nodesVisited := nodesVisited + 1.	"See if there's already something in the transposition table. If so, skip the entire search."	entry := transTable lookupBoard: theBoard.	alpha := initialAlpha.	beta := initialBeta.	(entry isNil or: [entry depth < depth]) 		ifFalse: 			[ttHits := ttHits + 1.			(entry valueType bitAnd: 1) = (ply bitAnd: 1) 				ifTrue: [beta := entry value max: initialBeta]				ifFalse: [alpha := 0 - entry value max: initialAlpha].			beta > initialBeta ifTrue: [^beta].			alpha >= initialBeta ifTrue: [^alpha]].	bestScore := AlphaBetaMinVal.	"Generate new moves"	moveList := generator findPossibleMovesFor: theBoard activePlayer.	moveList ifNil: [^0 - AlphaBetaIllegal].	moveList isEmpty 		ifTrue: 			[generator recycleMoveList: moveList.			^bestScore].	"Sort move list according to history heuristics"	moveList sortUsing: historyTable.	"And search"	a := alpha.	b := beta.	notFirst := false.	[(move := moveList next) isNil] whileFalse: 			[newBoard := (boardList at: ply + 1) copyBoard: theBoard.			newBoard nextMove: move.			"Search recursively"			ply := ply + 1.			score := 0 - (self 								ngSearch: newBoard								depth: depth - 1								alpha: 0 - b								beta: 0 - a).			(notFirst and: [score > a and: [score < beta and: [depth > 1]]]) 				ifTrue: 					[score := 0 - (self 										ngSearch: newBoard										depth: depth - 1										alpha: 0 - beta										beta: 0 - score)].			notFirst := true.			ply := ply - 1.			stopThinking 				ifTrue: 					[generator recycleMoveList: moveList.					^score].			score = AlphaBetaIllegal 				ifFalse: 					[score > bestScore 						ifTrue: 							[ply < 10 ifTrue: [self copyVariation: move].							bestScore := score].					score > a 						ifTrue: 							[a := score.							a >= beta 								ifTrue: 									[transTable 										storeBoard: theBoard										value: score										type: (ValueBoundary bitOr: (ply bitAnd: 1))										depth: depth										stamp: stamp.									historyTable addMove: move.									alphaBetaCuts := alphaBetaCuts + 1.									generator recycleMoveList: moveList.									^score]].					b := a + 1]].	transTable 		storeBoard: theBoard		value: bestScore		type: (ValueAccurate bitOr: (ply bitAnd: 1))		depth: depth		stamp: stamp.	generator recycleMoveList: moveList.	^bestScore! !!PlayingCardDeck methodsFor: 'private' stamp: 'djp 10/16/1999 17:27'!nilOrSymbol: aSymbolOrString	(nil = aSymbolOrString or:	 ['nil' = aSymbolOrString or:	 [aSymbolOrString isEmpty]])		ifTrue: [^nil]		ifFalse: [^aSymbolOrString asSymbol]! !!WordGameLetterMorph methodsFor: 'initialization' stamp: 'di 5/8/2000 11:22'!normalColor	^ Color r: 1.0 g: 0.8 b: 0.2! !!ChessBoard methodsFor: 'moving' stamp: 'aoy 2/17/2003 01:16'!nullMove	activePlayer := activePlayer == whitePlayer 				ifTrue: [blackPlayer]				ifFalse: [whitePlayer]. 	activePlayer prepareNextMove! !!TetrisBoard methodsFor: 'data' stamp: 'RAA 8/28/1999 23:29'!numColumns	^10	! !!ChessPlayer methodsFor: 'accessing' stamp: 'ar 8/9/2001 17:56'!numPawns	^numPawns! !!TetrisBoard methodsFor: 'data' stamp: 'RAA 8/28/1999 23:30'!numRows	^27	! !!FreeCellStatistics methodsFor: 'actions' stamp: 'djp 10/24/1999 17:15'!ok	window delete.	window _ nil.! !!ChineseCheckers methodsFor: 'drag and drop' stamp: 'di 4/8/2000 23:45'!okToPickUpPieceAt: boardLoc	^ (self at: boardLoc) = whoseMove and: [(autoPlay at: whoseMove) not]! !!CrosticPanel class methodsFor: 'as yet unclassified' stamp: 'di 5/12/2000 15:12'!oldStyle	"return true if we should cross-index all the cells (takes more space)."	^ false! !!ChessMoveList methodsFor: 'private' stamp: 'ar 8/24/2001 16:10'!on: aCollection from: firstIndex to: lastIndex	startIndex _ firstIndex.	^super on: aCollection from: firstIndex to: lastIndex.! !!CrosticPanel methodsFor: 'menu' stamp: 'asm 11/25/2003 22:26'!openFile	| stdFileMenuResult crostic file |	stdFileMenuResult :