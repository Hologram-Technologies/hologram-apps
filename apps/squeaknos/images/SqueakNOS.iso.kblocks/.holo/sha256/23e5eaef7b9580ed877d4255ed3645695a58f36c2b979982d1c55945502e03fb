 	myActor resizeRightNow: scale undoable: false.
	handle position: evt cursorPoint - (handle extent // 2).! !!WonderlandWrapperMorph methodsFor: 'handles' stamp: 'ar 11/8/1999 15:20'!growPositionOffset
