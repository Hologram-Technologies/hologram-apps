		"Dump it. We may just being dragged around by the hand."
		myRenderer destroy.
		myRenderer _ nil].
	aCanvas asBalloonCanvas render: self.
	outline ifNotNil:[self sketchOn: aCanvas].! !!WonderlandCameraMorph methodsFor: 'drawing' stamp: 'ar 5/14/2001 23:09'!forceToScreen
