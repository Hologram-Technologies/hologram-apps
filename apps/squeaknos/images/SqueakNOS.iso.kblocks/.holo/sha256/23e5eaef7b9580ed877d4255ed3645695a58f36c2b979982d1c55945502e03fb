	actor _ myActor getParent.
	actor == myWonderland getScene ifTrue:[^self]. "At top"
	"Create new wrapper"
	wrapper _ self class on: actor.
	wrapper addMorphFront: self.
	"And continue there"
	^wrapper createHierarchy! !!WonderlandWrapperMorph methodsFor: 'initialization' stamp: 'ar 11/7/1999 19:03'!setActor: anActor
