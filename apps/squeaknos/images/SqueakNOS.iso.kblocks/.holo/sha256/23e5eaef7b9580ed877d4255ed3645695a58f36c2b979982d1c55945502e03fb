		ifTrue:[self setProperty: #accelerationSuspended toValue: aBool]
		ifFalse:[self removeProperty: #accelerationSuspended]! !!WonderlandCameraMorph methodsFor: 'hardware acceleration' stamp: 'ar 4/20/2001 02:14'!restoreAcceleration
