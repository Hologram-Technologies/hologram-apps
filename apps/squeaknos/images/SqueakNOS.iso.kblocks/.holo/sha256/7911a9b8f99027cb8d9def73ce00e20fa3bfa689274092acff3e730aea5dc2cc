					from _ (m to) + 1.
					(0 = m match size)
						ifTrue: [ "Handle an empty match"
							from _ from + 1.
							(lastMatchFrom = m from) 
								ifFalse: [results add:(aBlock value: m)]]
						ifFalse: [ "Handle a non-empty match"
							lastMatchFrom _ from. 
							results add:(aBlock value: m)]]].
