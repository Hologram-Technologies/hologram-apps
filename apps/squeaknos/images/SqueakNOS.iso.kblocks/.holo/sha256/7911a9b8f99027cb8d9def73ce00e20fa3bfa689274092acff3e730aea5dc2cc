	aString ifNil: [^nil].
	from _ 1. to _ aString size. lastMatchFrom _ -1. matchesSoFar _ 0.
	results  _ OrderedCollection new.

	[from <= (to+1)]
		whileTrue: [
			(m _ self search: aString from: from to: to opt: optString)
				ifNil: [
					(0 = results size) ifTrue: [^nil].
					^results]
				ifNotNil: [
