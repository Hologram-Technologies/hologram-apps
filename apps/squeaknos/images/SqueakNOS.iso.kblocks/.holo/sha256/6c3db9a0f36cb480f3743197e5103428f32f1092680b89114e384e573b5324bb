[:ea | 		ea removeFromSystem].		self registerForFileList.! !!MczInstaller class methodsFor: 'versionInfo' stamp: 'avi 2/17/2004 02:49'!versionInfo	^ Versions! !!MenuIcons commentStamp: 'sd 11/9/2003 14:09' prior: 0!I represent a registry for icons.  You can see the icons I contain using the following script:| dict methods |dict := Dictionary new. methods := MenuIcons class selectors select: [:each | '*Icon' match: each asString].methods do: [:each | dict at: each put: (MenuIcons perform: each)].GraphicalDictionaryMenu openOn: dict withLabel: 'MenuIcons'!!MenuIcons class methodsFor: 'accessing - icons' stamp: 'sd 11/11/2003 11:31'!appearanceIcon^ Icons		at: #appearanceIcon ifAbsentPut: [((ColorForm	extent: 16@16	depth: 8	fromArray: #( 4294967295 4294914610 1261581055 4294967295 4294967078 623850055 1262304536 553648127 4294914607 1412644660 1442878037 789774335 4280635289 328705 963542642 2571702015 4282131736 1176307975 1432640097 1586838527 993792806 224354447 2407892317 1603437837 1247750183 1015843973 2340717698 1989375523 1318556043 2340714370 2004316529 2140372782 407732874 2172024433 1532717146 1752262444 4279898433 2172025179 1751672644 976899103 4294967059 744184680 1532783892 33756182 4294967295 322984808 1129334839 101063935 4294967295 4279068775 757801555 1666714879 4294967295 4294909784 1498567000 1461059583 4294967295 4294967053 371085598 184549375 4294967295 4294967295 169221642 4294967295)	offset: 0@0)	colorsFromArray: #(#(1.0 1.0 1.0) #(0.129 0.646 1.0) #(0.129 0.905 0.223) #(0.129 0.968 0.258) #(0.16 0.71 1.0) #(0.258 0.678 1.0) #(0.258 0.905 0.129) #(0.289 0.741 0.905) #(0.289 0.87 0.094) #(0.321 0.807 0.968) #(0.419 0.258 0.16) #(0.419 0.548 0.0) #(0.451 0.223 0.063) #(0.451 0.289 0.16) #(0.451 0.321 0.223) #(0.482 0.289 0.129) #(0.482 0.289 0.16) #(0.482 0.321 0.16) #(0.482 0.353 0.258) #(0.482 0.388 0.289) #(0.482 0.548 0.0) #(0.517 0.223 0.031) #(0.517 0.258 0.063) #(0.517 0.258 0.094) #(0.517 0.353 0.192) #(0.517 0.353