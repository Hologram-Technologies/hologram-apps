	| name percent |
	name := nil.
	percent := 1.0.
	self recognize:#(
		(16rA300 cString texName)
		(16r0030 short texPercent)
		(16r0031 float texPercent))
	do:[:item|
		item key == #texName ifTrue:[name := item value].
		item key == #texPercent ifTrue:[percent := item value / 100.0]].
	^Array 	with:(#textureName -> name)
			with: (#texturePercentage -> percent).! !!ThreeDSParser methodsFor: 'reading-material' stamp: 'ar 2/6/1999 23:29'!textureVertices
	"Subchunk of tri object"
	| nVerts texCoords u v |
	nVerts := self uShort.
	texCoords := self textureArrayClass new: nVerts.
	1 to: nVerts do:[:i|
		u := self float.
		v := self float.
		texCoords at: i put: (u@v).
	].
	^texCoords.! !!ThreeDSParser methodsFor: 'reading-material'!verticalGradient

	| midPt start mid stop|
