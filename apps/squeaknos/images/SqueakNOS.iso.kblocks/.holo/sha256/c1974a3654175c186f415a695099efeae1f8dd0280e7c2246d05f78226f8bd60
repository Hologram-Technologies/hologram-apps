	"Read keyframes interpolating a vector (position, scale)"
	| vector spec splClass |
	^self trackCollect: [:params|
		params ifNil:[spec _ Dictionary new] ifNotNil:[spec _ params].
		vector := self vector3.
		spec at: #position put: vector.
