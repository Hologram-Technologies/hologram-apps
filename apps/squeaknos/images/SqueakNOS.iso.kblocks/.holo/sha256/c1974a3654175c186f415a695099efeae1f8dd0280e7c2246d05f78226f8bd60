			ifTrue: 
				[self triangulation removeTriangle: triangle.
				outer _ edge next.
				fanCenter _ edge midpoint.
				"self triangulation removeEdge: edge."
				[outer origin = edge origin]
					whileFalse: 
						[further _ outer next.
						self triangulation
							triangle: fanCenter
							to: outer origin
							to: outer destination.
						outer _ further]].
