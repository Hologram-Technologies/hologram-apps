	inner do: [:face | face edges do: 
			[:halfedge | 
			halfedge clearTag: #border.
			halfedge opposite clearTag: #border]]! !!POObject methodsFor: 'skeleton' stamp: 'laza 1/17/2000 12:04'!tailor
