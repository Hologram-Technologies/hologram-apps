/*	Rotate the given 32-bit integer left by the given number of bits and answer the result. */

static sqInt leftRotateby(unsigned int  anInteger, sqInt bits) {
	return (anInteger << bits) | (((usqInt) anInteger) >> (32 - bits));
}

