dsFor: '*network-Mail Reader-Spam' stamp: 'dms 7/4/2004 18:54'!orderedCounts	"Answer with a collection of counts with elements, sorted by decreasing	count.	Similar to sortedCounts, but:	(a) returns an Array	(b) uses Array's merge sort rather than SortedCollection's heap sort"	| idx sortedCounts |	sortedCounts := Array new: contents size.	idx := 1.	contents associationsDo: [:assoc |		sortedCounts at: idx put: (Association key: assoc value value: assoc key).		idx := idx + 1	].	sortedCounts sort: [:x :y | x >= y].	^sortedCounts! !!Bag methodsFor: '*network-Mail Reader-Categorizer' stamp: 'ads 11/16/2003 22:10'!readFrom: aStream elementReader: aBlock	| numberOfDistinctElements count x |	numberOfDistinctElements _ aStream binary; nextInt32.	numberOfDistinctElements timesRepeat: [		count _ aStream binary; nextInt32.		x _ aBlock value: aStream.		self add: x withOccurrences: count.	].! !!Bag methodsFor: '*network-Mail Reader-Spam' stamp: 'ads 9/12/2003 22:53'!removeAllButMostProminent: numberToKeep	| sorted |	sorted _ self sortedCounts.	((sorted last: (sorted size - numberToKeep)) collect: [:a | a value]) do: [:e | self removeAllCopiesOf: e].! !!Bag methodsFor: '*network-Mail Reader-Spam' stamp: 'ads 11/16/2003 19:35'!valuesAndCounts	^ contents! !!Bag methodsFor: '*network-Mail Reader-Categorizer' stamp: 'ads 11/16/2003 22:12'!writeOn: aStream elementWriter: aBlock	aStream binary.	aStream nextInt32Put: contents size.	contents keysAndValuesDo: [:x :count |		aStream nextInt32Put: count.		aBlock value: aStream value: x.	].! !!TextMessageLink commentStamp: '<historical>' prior: 29657854!A link to a hidden mail message.  Clicking on it allows the message to be viewed or saved to disk.!!TextMessageLink class methodsFor: 'instance creation' stamp: 'ls 4/30/2000 19:00' prior: 29658942!message: aMessage	^super new initialize: aMessage! !!TextMessageLink methodsFor: 'acting' stamp: 'sbw 1/21/2001 19:48' prior: 29658146!actOnClickFor: e